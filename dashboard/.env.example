# Copy to .env(.local) for local dev, or set as build-time env vars on Vercel.
# All Vite env vars must be prefixed VITE_ to be exposed to client code.

# Base URL of the deployed API (Railway). Leave empty for local dev — Vite's
# dev server proxy (vite.config.ts) forwards /api to the local Fastify server.
VITE_API_BASE_URL=

# --- Supabase Auth (SSO login, see src/lib/supabaseClient.ts) --------------------
# Project Settings > API. The anon key is safe to expose client-side — it's
# the publishable key, not a secret. Both can be left blank — the app runs
# fine without them (see VITE_REQUIRE_AUTH below); they're only needed once
# you actually want the Login page to work.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Rollout kill switch, default "false" (or unset) — mirrors the backend's own
# REQUIRE_AUTH (see root .env.example). While false, the router never
# redirects to /login, so the app works exactly as it did before login
# existed. Flip to "true" once Supabase Auth providers are configured and
# you're ready to actually require sign-in — do this alongside setting the
# backend's REQUIRE_AUTH=true, not instead of it.
VITE_REQUIRE_AUTH=false
