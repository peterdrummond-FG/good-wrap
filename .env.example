# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Real per-user login (Supabase Auth SSO, 2026-07-20) -------------------------
# See src/server/auth.ts. Enable Google + Microsoft (Azure AD) providers in the
# Supabase project's Authentication settings first.

# Your Supabase project's URL (Project Settings > API) — used to fetch its
# JWKS for verifying dashboard session tokens.
SUPABASE_URL=

# Rollout kill switch, default "false". While false, a request with no valid
# credentials still resolves to the legacy DEFAULT_OWNER_EMAIL/
# LOCAL_WORKER_API_KEY single-user assumption instead of being rejected — set
# to "true" once the frontend is confirmed sending real bearer tokens and the
# local watch-folder scripts are confirmed sending personal worker keys. A
# validly-signed-in but uninvited SSO login is rejected either way.
REQUIRE_AUTH=false

# 32-byte key (base64), generate with: openssl rand -base64 32. Encrypts
# per-user Zoom/Asana OAuth tokens at rest (src/util/tokenCrypto.ts) — never
# reuse across environments, never commit.
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# Signs the OAuth CSRF `state` param (src/util/oauthState.ts) — any random
# string works, generate with: openssl rand -base64 32.
OAUTH_STATE_SECRET=

# The dashboard's own public URL — where OAuth callbacks redirect back to
# once a Zoom/Asana connection completes (e.g. https://good-wrap.vercel.app,
# or http://localhost:5173 for local dev).
DASHBOARD_BASE_URL=

# --- Per-user Zoom OAuth (Account page's "Connect Zoom") -------------------------
# A separate "User-managed OAuth" app in the Zoom Marketplace — distinct from
# the Server-to-Server app below, which stays account-wide for the recording
# webhook. Scopes: cloud_recording:read, meeting:read. Redirect URI:
# <GOODWRAP_API_BASE_URL>/api/integrations/zoom/callback.
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=

# --- Per-user Asana OAuth (Account page's "Connect Asana") -----------------------
# A separate OAuth app registration (Asana > profile photo > Settings > Apps >
# Manage Developer Apps) — distinct from the legacy Personal Access Token
# below, which stays as a fallback for anyone who hasn't connected their own
# account yet. Redirect URI: <GOODWRAP_API_BASE_URL>/api/integrations/asana/callback.
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=

# Supabase Postgres connection string.
# Project Settings > Database > Connection string > URI.
# Use the "Transaction" pooler string for serverless/edge use; the direct
# connection string also works fine for long-running scripts like the Stage 0 CLI.
DATABASE_URL=

# Email of the users row that owns meetings captured without an explicit
# ownerEmail (see src/ingest/captureManualMeeting.ts). Must already exist in
# the `users` table.
DEFAULT_OWNER_EMAIL=owner@example.com

# --- Stage 2: processing pipeline ---------------------------------------------

# Anthropic API key, for Claude extraction of keywords/takeaways/follow-ups
# (src/pipeline/extractInsights.ts). Get one at console.anthropic.com.
# Note: this is a separate credential from your Claude.ai/Claude Code login.
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5 if unset.
CLAUDE_MODEL=

# Embeddings (src/pipeline/embedChunks.ts) run entirely locally via fastembed
# (BAAI/bge-small-en-v1.5, ONNX Runtime) — no API key needed. First run
# downloads the model (~130MB) and caches it; every run after is offline.

# Optional — where fastembed caches the downloaded model. Defaults to a
# `local_cache/` folder created in the project root if unset (gitignored).
FASTEMBED_CACHE_DIR=

# --- Deployment (Railway API / Vercel dashboard) ---------------------------------

# Optional, comma-separated. Extra origins allowed to call this API (see
# src/server/app.ts) on top of the built-in defaults (localhost:5173 and
# https://good-wrap.vercel.app). Add a Vercel preview-deployment URL here if
# you need one temporarily allowed — no code change/redeploy needed.
ALLOWED_ORIGINS=

# --- Stage 3: notifications -----------------------------------------------------
# Email and chat-style ping are currently stubs (see src/notify/channels/) —
# no provider has been chosen yet. They print what would be sent and log
# "pending" in notifications_log instead of actually delivering anything.
# No env vars needed until a real provider is wired in.

# --- Folder auto-scan (.claude/skills/process-transcripts/SKILL.md) ------------
# Reworked 2026-07-17: a local Claude Code session now generates meeting
# insights itself (billed to Peter's Claude Code plan/session usage) instead
# of scanFolder.ts calling extractInsights() via ANTHROPIC_API_KEY. Automation
# still runs via the local macOS launchd job (com.goodwrap.scanfolder.plist,
# every 20 min, no session needed) — it now invokes `claude -p` headlessly
# instead of `npm run scan-folder` directly. src/ingest/scanFolder.ts still
# handles the deterministic file-locking/move mechanics the skill shells out
# to (list/claim/finish subcommands).

# Absolute path to the folder on this machine holding .txt transcripts to
# auto-capture. Only read locally (not by the deployed Railway API).
TRANSCRIPT_WATCH_DIR=

# Base URL of the deployed API (Railway) — the local skill POSTs the
# transcript + its own generated insights here once processed. Use
# http://localhost:PORT for local dev/testing against `npm run api`.
GOODWRAP_API_BASE_URL=

# LEGACY, 2026-07-20 — per-user worker keys (issued from the Account page's
# Local Setup tab, see db/schema.ts's worker_api_keys table) replace this.
# Kept only as a rollout fallback (src/server/auth.ts's resolveFromWorkerKey)
# so an existing local setup keeps working unmodified until it's migrated to
# a personal key — remove this var (and the fallback branch) once every
# active user has migrated. Set the SAME value here and in the server's own
# .env (Railway) if you do still rely on it.
LOCAL_WORKER_API_KEY=

# --- Zoom webhook (src/integrations/zoom.ts, POST /api/webhooks/zoom) -----------
# From a Server-to-Server OAuth app in the Zoom Marketplace (scopes:
# cloud_recording:read, meeting:read), plus a webhook subscription for
# "Recording Transcript files have completed" pointed at this API's
# /api/webhooks/zoom.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# --- Asana push (Action Items "Send to Asana" button, src/integrations/asana.ts) -
# LEGACY fallback, 2026-07-20 — used only when the clicking user hasn't
# connected their own Asana account yet (see ASANA_OAUTH_CLIENT_ID above and
# queries.ts's sendActionItemToAsana). Personal Access Token — Asana > profile
# photo > Settings > Apps > Manage Developer Apps > Create new token.
ASANA_ACCESS_TOKEN=

# Workspace/project to create tasks in (find via GET /api/1.0/workspaces and
# GET /api/1.0/workspaces/{gid}/projects). Tasks are also created with
# assignee: "me", so they show up in the token owner's My Tasks too.
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
