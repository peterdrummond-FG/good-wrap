# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Supabase Postgres connection string.
# Project Settings > Database > Connection string > URI.
# Use the "Transaction" pooler string for serverless/edge use; the direct
# connection string also works fine for long-running scripts like the Stage 0 CLI.
DATABASE_URL=

# Email of the users row that owns meetings captured without an explicit
# ownerEmail (see src/ingest/captureManualMeeting.ts). Must already exist in
# the `users` table.
DEFAULT_OWNER_EMAIL=peter.drummond@flippengroup.com

# --- Stage 2: processing pipeline ---------------------------------------------

# Anthropic API key, for Claude extraction of keywords/takeaways/follow-ups
# (src/pipeline/extractInsights.ts). Get one at console.anthropic.com.
# Note: this is a separate credential from your Claude.ai/Claude Code login.
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5 if unset.
CLAUDE_MODEL=

# Embeddings (src/pipeline/embedChunks.ts) run entirely locally via fastembed
# (BAAI/bge-small-en-v1.5, ONNX Runtime) — no API key needed. First run
# downloads the model (~130MB) and caches it; every run after is offline.

# Optional — where fastembed caches the downloaded model. Defaults to a
# `local_cache/` folder created in the project root if unset (gitignored).
FASTEMBED_CACHE_DIR=

# --- Stage 3: notifications -----------------------------------------------------
# Email and chat-style ping are currently stubs (see src/notify/channels/) —
# no provider has been chosen yet. They print what would be sent and log
# "pending" in notifications_log instead of actually delivering anything.
# No env vars needed until a real provider is wired in.
